#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LAZYGIT_CONFIG_DIR=""

if command -v lazygit >/dev/null 2>&1; then
  LAZYGIT_CONFIG_DIR="$(lazygit --print-config-dir 2>/dev/null || true)"
fi

if [ -z "$LAZYGIT_CONFIG_DIR" ]; then
  if [ -d "$HOME/Library/Application Support/lazygit" ]; then
    LAZYGIT_CONFIG_DIR="$HOME/Library/Application Support/lazygit"
  else
    LAZYGIT_CONFIG_DIR="$HOME/.config/lazygit"
  fi
fi

mkdir -p \
  "$ROOT_DIR/atuin" \
  "$ROOT_DIR/atuin/themes" \
  "$ROOT_DIR/bin" \
  "$ROOT_DIR/eza" \
  "$ROOT_DIR/fish" \
  "$ROOT_DIR/git" \
  "$ROOT_DIR/git-config" \
  "$ROOT_DIR/htop" \
  "$ROOT_DIR/iterm2" \
  "$ROOT_DIR/lazygit" \
  "$ROOT_DIR/nvim" \
  "$ROOT_DIR/tmux" \
  "$ROOT_DIR/yazi" \
  "$ROOT_DIR/zsh" \
  "$ROOT_DIR/zsh/profile.d" \
  "$ROOT_DIR/zsh/rc.d"

rsync -a --delete \
  --exclude '.DS_Store' \
  --exclude '.cursor/' \
  "$HOME/.config/nvim/" "$ROOT_DIR/nvim/"

if [ -d "$HOME/.config/eza" ]; then
  rsync -a --delete --exclude '.DS_Store' "$HOME/.config/eza/" "$ROOT_DIR/eza/"
fi

if [ -f "$HOME/.config/atuin/config.toml" ]; then
  install -m 0644 "$HOME/.config/atuin/config.toml" "$ROOT_DIR/atuin/config.toml"
fi
if [ -d "$HOME/.config/atuin/themes" ]; then
  rsync -a --delete --exclude '.DS_Store' "$HOME/.config/atuin/themes/" "$ROOT_DIR/atuin/themes/"
fi

rsync -a --delete --exclude '.DS_Store' "$HOME/.config/fish/" "$ROOT_DIR/fish/"
rsync -a --delete --exclude '.DS_Store' "$HOME/.config/git/" "$ROOT_DIR/git/"
rsync -a --delete --exclude '.DS_Store' "$HOME/.config/htop/" "$ROOT_DIR/htop/"
if [ -d "$LAZYGIT_CONFIG_DIR" ]; then
  rsync -a --delete --exclude '.DS_Store' "$LAZYGIT_CONFIG_DIR/" "$ROOT_DIR/lazygit/"
fi
if [ -d "$HOME/.config/yazi" ]; then
  rsync -a --delete --exclude '.DS_Store' "$HOME/.config/yazi/" "$ROOT_DIR/yazi/"
fi

install -m 0644 "$HOME/.gitconfig" "$ROOT_DIR/git-config/.gitconfig"
install -m 0644 "$HOME/.gitignore_global" "$ROOT_DIR/git-config/.gitignore_global"
perl -0pi -e '
  s#^(\s*excludesfile\s*=\s*).*$#$1~/.gitignore_global#mg;
' "$ROOT_DIR/git-config/.gitconfig"

echo "Skipping zsh loader/module sync: dotfiles is the source of truth for zsh."

install -m 0644 "$HOME/.tmux.conf" "$ROOT_DIR/tmux/.tmux.conf"
perl -0pi -e '
  s#~/.config/tmux/tmux\.conf#~/.tmux.conf#g;
  s#~/.config/tmux/plugins/catppuccin/tmux#~/.tmux/plugins/catppuccin#g;
  s#~/.config/tmux/plugins/tmux-plugins/tmux-cpu/cpu\.tmux#~/.tmux/plugins/tmux-cpu/cpu.tmux#g;
  s#~/.config/tmux/plugins/tmux-plugins/tmux-battery/battery\.tmux#~/.tmux/plugins/tmux-battery/battery.tmux#g;
' "$ROOT_DIR/tmux/.tmux.conf"

if [ -f "$HOME/bin/tmxp" ]; then
  install -m 0755 "$HOME/bin/tmxp" "$ROOT_DIR/bin/tmxp"
fi

plutil -convert xml1 -o "$ROOT_DIR/iterm2/com.googlecode.iterm2.plist" \
  "$HOME/Library/Preferences/com.googlecode.iterm2.plist"

echo "Sync complete. Review with: git status --short"
