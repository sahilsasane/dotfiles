#!/usr/bin/env bash
set -euo pipefail

die() {
  printf '%s\n' "$*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "lg-ai-commit: '$1' is required."
}

cleanup() {
  local status=$?

  if [[ -n "${__lg_ai_commit_tmp:-}" && -f "${__lg_ai_commit_tmp}" ]]; then
    rm -f "${__lg_ai_commit_tmp}"
  fi

  exit "$status"
}

trap cleanup EXIT

require_cmd git
require_cmd mktemp
require_cmd fzf

if ! command -v aichat >/dev/null 2>&1; then
  die "lg-ai-commit: aichat is not installed. Install it with 'brew install aichat' and configure a model with 'aichat'."
fi

git rev-parse --git-dir >/dev/null 2>&1 || die "lg-ai-commit: not a git repository."
git diff --staged --quiet && die "lg-ai-commit: no staged changes."

recent_count="${LG_AI_COMMIT_RECENT_COUNT:-15}"
suggestion_count="${LG_AI_COMMIT_SUGGESTIONS:-10}"
diff_chars="${LG_AI_COMMIT_DIFF_CHARS:-120000}"
recent_chars="${LG_AI_COMMIT_RECENT_CHARS:-4000}"

# Avoid SIGPIPE/141 under `set -o pipefail` by truncating in bash rather than `head -c`.
staged_diff="$(git diff --staged --patch --minimal)"
staged_diff="${staged_diff:0:${diff_chars}}"

recent_commits="$(git log -n "${recent_count}" --pretty=format:%s 2>/dev/null | sed 's/^/- /')"
recent_commits="${recent_commits:0:${recent_chars}}"

prompt=$'You write git commit message candidates for the STAGED diff only.\n\n'\
$'Use the recent commit subjects only to infer style and level of abstraction, not to copy content.\n\n'\
$'Requirements:\n'\
$'- Return exactly '"${suggestion_count}"$' commit message candidates\n'\
$'- Output raw commit subjects only, one per line\n'\
$'- No numbering, bullets, quotes, markdown, or commentary\n'\
$'- Follow Conventional Commits exactly in the form <type>[optional scope][optional !]: <description>\n'\
$'- Use lowercase Conventional Commit types such as feat, fix, docs, refactor, chore, test, build, ci, perf, style, or revert\n'\
$'- Every candidate MUST start with a type, followed by the optional scope, optional !, and a required colon and space\n'\
$'- Use feat when the full staged change set primarily adds a feature\n'\
$'- Use fix when the full staged change set primarily fixes a bug\n'\
$'- Types other than feat and fix may be used when they fit the full staged change set better\n'\
$'- Use a scope only when it is genuinely helpful for the overall staged change set\n'\
$'- If a scope is used, it must be a noun describing the main affected area and must appear in parentheses, for example feat(parser): ...\n'\
$'- The description must immediately follow the colon and space and must be a short summary of the full staged change set\n'\
$'- Prefer higher-level intent over low-level code narration\n'\
$'- Keep each subject concise and under 72 characters when possible\n'\
$'- Because this tool outputs subject lines only, do not output a body or footers\n'\
$'- Base every candidate on the STAGED diff, not unstaged changes\n'\
$'- This tool is generating candidates for exactly one git commit being made now\n'\
$'- Every candidate must describe the full staged change set as one commit\n'\
$'- Do not split the staged work into separate per-task, per-file, or per-concern subjects\n'\
$'- Never suggest multiple commits, a commit plan, or subjects like "commit 1" / "commit 2"\n'\
$'- Choose exactly one type and optional scope per candidate, based on the primary overall intent of the full staged diff\n'\
$'- If the full staged change set is breaking, mark it with ! immediately before the colon\n'\
$'- Do not output BREAKING CHANGE footers because this tool outputs subjects only\n'\
$'- Different candidates may vary in wording or abstraction, but they must all cover the same overall change\n'\
$'- If the diff spans multiple edits, still write one subject that summarizes the combined overall outcome being committed\n'\
$'- If a scope is used, it must name the main area affected by the whole staged change set, not one subtask\n\n'\
$'Recent commit subjects:\n'\
"${recent_commits:-"- none"}"\
$'\n\nSTAGED DIFF:\n'\
"$staged_diff"

selected_message="$(
  aichat "$prompt" \
    | sed '/^[[:space:]]*$/d' \
    | fzf --height 40% --border --ansi --preview 'printf "%s\n" {}' --preview-window=up:wrap
)"

__lg_ai_commit_tmp="$(mktemp "${TMPDIR:-/tmp}/lg-ai-commit.XXXXXX")"
printf '%s\n' "${selected_message}" > "${__lg_ai_commit_tmp}"

if [[ ! -s "${__lg_ai_commit_tmp}" ]]; then
  die "lg-ai-commit: no commit message selected."
fi

"${VISUAL:-${EDITOR:-vi}}" "${__lg_ai_commit_tmp}"

if ! grep -q '[^[:space:]]' "${__lg_ai_commit_tmp}"; then
  die "lg-ai-commit: empty commit message after edit."
fi

git commit -F "${__lg_ai_commit_tmp}" "$@"
