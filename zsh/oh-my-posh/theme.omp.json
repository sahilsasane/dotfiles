{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "plain",
          "foreground": "#ffffff",
          "template": " {{ if .WSL }}WSL{{ else }}{{ .Icon }}{{ end }} "
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "#fab387",
          "template": "´ü╝ {{ .Path }} ",
          "properties": {
            "style": "folder"
          }
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#cba6f7",
          "template": "´çô ¯éá {{ .HEAD }}{{ if gt .Behind 0 }} <#f9e2af>Ôçú{{ .Behind }}</>{{ end }}{{ if gt .Ahead 0 }} <#fab387>Ôçí{{ .Ahead }}</>{{ end }}{{ if gt .PushBehind 0 }} <#f2cdcd>Ôçá{{ .PushBehind }}</>{{ end }}{{ if gt .PushAhead 0 }} <#f5c2e7>Ôçó{{ .PushAhead }}</>{{ end }}{{ if .UpstreamGone }} <#f38ba8>´äº</>{{ end }}{{ if .Merge }} <#eba0ac>¯£º</>{{ end }}{{ if .Rebase }} <#fab387>¯®ñ{{ .Rebase.Current }}/{{ .Rebase.Total }}</>{{ end }}{{ if .CherryPick }} <#f5c2e7>¯èø</>{{ end }}{{ if .Revert }} <#f2cdcd>ÔåÂ</>{{ end }}{{ if gt .StashCount 0 }} <#f5e0dc>´âç{{ .StashCount }}</>{{ end }}{{ if .Working.Changed }} <#f38ba8>´üä {{ .Working.String }}</>{{ end }}{{ if .Staging.Changed }} <#f9e2af>´üå {{ .Staging.String }}</>{{ end }} ",
          "properties": {
            "branch_icon": "",
            "fetch_status": true,
            "fetch_push_status": true,
            "status_formats": {
              "Unmerged": "¯£º%d",
              "Added": "+%d",
              "Modified": "~%d",
              "Deleted": "-%d",
              "Untracked": "?%d"
            }
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "#f9e2af",
          "template": "¯«ó {{ .FormattedMs }} ",
          "properties": {
            "threshold": 1000,
            "style": "austin"
          }
        },
        {
          "type": "python",
          "style": "plain",
          "foreground": "#89b4fa",
          "template": "¯êÁ {{ .Venv }} ",
          "properties": {
            "display_mode": "environment",
            "fetch_version": false,
            "fetch_virtual_env": true,
            "display_default": false
          }
        },
        {
          "type": "battery",
          "style": "plain",
          "foreground": "#f9e2af",
          "template": "{{ if not .Error }}{{ .Icon }}{{ .Percentage }}{{ end }} ",
          "properties": {
            "charging_icon": "´âº ",
            "discharging_icon": "¾░ü╣ ",
            "charged_icon": "¾░éä ",
            "not_charging_icon": "¾▒ƒó "
          }
        },
        {
          "type": "time",
          "style": "plain",
          "foreground": "#fab387",
          "template": "´Çù {{ .CurrentDate | date .Format }} ",
          "properties": {
            "time_format": "15:04:05"
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#ffffff",
          "template": "Ôò░ÔöÇÔØ» "
        }
      ]
    }
  ]
}
