unalias ls l la ll lsa tree 2>/dev/null

alias ls='eza --icons --group-directories-first'
alias l='eza -la --git --icons --group-directories-first'
alias la='eza -a --git --icons --group-directories-first'
alias ll='eza -lh --git --icons --group-directories-first'
alias tr='eza --tree --git --icons'
