% migrations, personal, db, sql

# Create a new SQL migration
migrate create -seq -ext=.sql -dir=./migrations <migration_name>

# Apply pending SQL migrations
migrate -path=./migrations -database=$GREENLIGHT_DB_DSN up

# Generate an Alembic migration
uv run alembic revision --autogenerate -m "<message>"

# Apply Alembic migrations
uv run alembic upgrade head

# Roll back one Alembic migration
uv run alembic downgrade -1

# SQLite table alteration pattern
op.batch_alter_table(<table_name>)

